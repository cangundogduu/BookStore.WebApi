@using BookStore.WebUI.Dtos.QuoteDto
@model GetByIdQuoteDto
@{
    ViewData["Title"] = "UpdateQuote";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container text-center">
    <br /><br />
    <form method="post">
        <input type="hidden" asp-for="QuoteId" />
        <label>Alıntı</label>
        <input type="text" asp-for="Text" class="form-control" />
        <br />
        <label>Yazar</label>
        <input type="text" asp-for="Author" class="form-control" />
        <br />
        <button class="btn btn-primary">Alıntı Güncelle</button>
    </form>
</div>