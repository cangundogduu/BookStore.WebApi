@model BookStore.WebUI.Dtos.ProductDtos.CreateProductDto
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
@* <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" /> *@

<form method="post" action="/Product/CreateProduct">
    <div class="container">
        <br /><br />
        <label>Ürün Adı</label>
        <input type="text" class="form-control" asp-for="ProductName" />
        <br />
        <label>Kategori</label>
        <input type="text" class="form-control" asp-for="CategoryId" />
        <br />
        <label>Ürün Fiyatı</label>
        <input type="text" class="form-control" asp-for="ProductPrice" />
        <br />
        <label>Ürün Stok Sayısı</label>
        <input type="text" class="form-control" asp-for="ProductStock" />
        <br />
        <button type="submit" class="btn btn-success">Kaydet</button>
    </div>
</form>