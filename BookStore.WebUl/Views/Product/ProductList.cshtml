@model List<BookStore.WebUI.Dtos.ProductDtos.ResultProductDto>
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@* <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" /> *@

<div class="container">
    <br /><br />

    <table class="table table-striped table-hover">
        <tr>
            <th>#</th>
            <th>Ürün Adı</th>
            <th>Kategori</th>
            <th>Ürün Stok</th>
            <th>Ürün Fiyat</th>
            <th>Sil</th>
            <th>Güncelle</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.ProductId</td>
                <td>@item.ProductName</td>
                <td>@item.CategoryId</td>
                <td>@item.ProductStock</td>
                <td>@item.ProductPrice</td>
                <td><a href="/Product/DeleteProduct/@item.ProductId" class="btn btn-danger">Sil</a></td>
                <td><a href="/Product/UpdateProduct/@item.ProductId" class="btn btn-success">Güncelle</a></td>
            </tr>
        }

    </table>

    <a href="/Product/CreateProduct/" class="btn btn-success">Yeni Ürün Girişi</a>

</div>

