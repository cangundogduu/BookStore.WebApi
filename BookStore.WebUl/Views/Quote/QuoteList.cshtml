@using BookStore.WebUI.Dtos.QuoteDto
@model List<ResultQuoteDto>


@{
    ViewData["Title"] = "QuoteList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container text-center">
    <br /><br />
    <table class="table table-striped table-hover">
        <tr>
            <th>#</th>
            <th>Alıntı</th>
            <th>Yazar</th>
            <th>İşlemler</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.QuoteId</td>
                <td>@item.Text</td>
                <td>@item.Author</td>
                <td>
                    <a href="/Quote/UpdateQuote/@item.QuoteId" class="btn btn-success">Güncelle</a>
                    <a href="/Quote/DeleteQuote/@item.QuoteId" class="btn btn-danger">Sil</a>
                </td>
            </tr>
        }
    </table>
    <a href="/Quote/CreateQuote/" class="btn btn-primary">Yeni Alıntı Ekle </a>
</div>

