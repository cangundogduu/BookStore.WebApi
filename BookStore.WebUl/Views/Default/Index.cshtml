
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/UILayout/Index.cshtml";
}

@await Component.InvokeAsync("_DefaultSliderComponent")

<section id="client-holder" data-aos="fade-up">
	<div class="container">
		<div class="row">
			<div class="inner-content">
				<div class="logo-wrap">
					<div class="grid">
						<a href="#"><img src="~/booksaw-1.0.0/images/client-image1.png" alt="client"></a>
						<a href="#"><img src="~/booksaw-1.0.0/images/client-image2.png" alt="client"></a>
						<a href="#"><img src="~/booksaw-1.0.0/images/client-image3.png" alt="client"></a>
						<a href="#"><img src="~/booksaw-1.0.0/images/client-image4.png" alt="client"></a>
						<a href="#"><img src="~/booksaw-1.0.0/images/client-image5.png" alt="client"></a>
					</div>
				</div><!--image-holder-->
			</div>
		</div>
	</div>
</section>

@await Component.InvokeAsync("_DefaultFeaturedBooksComponent")

@await Component.InvokeAsync("_DefaultBestSellingBookComponent")

@await Component.InvokeAsync("_DefaultAllBooksComponent")

@* günün sözü alanı *@
<section id="quotation" class="align-center pb-5 mb-5">
	<div class="inner-content">
		<h2 class="section-title divider">Quote of the day</h2>
		<blockquote data-aos="fade-up">
			<q>
				“The more that you read, the more things you will know. The more that you learn, the more places
				you’ll go.”
			</q>
			<div class="author-name">Dr. Seuss</div>
		</blockquote>
	</div>
</section>

@await Component.InvokeAsync("_DefaultSubscribeComponent")

@await Component.InvokeAsync("_DefaultFooterComponent")